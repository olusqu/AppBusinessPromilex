<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - PROMILEX</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: '#B300FF',
        secondary: '#FF00A0',
        dark: '#0D051A',
        darker: '#1A0B2E'
        }
        }
        }
        }
    </script>
    <style>
        /* WYMUSZENIE CIEMNEGO TŁA - NAPRAWA BIAŁEGO TŁA */
        html, body {
        background: linear-gradient(135deg, #1A0B2E 0%, #0D051A 100%) !important;
        background-attachment: fixed !important;
        color: white !important;
        min-height: 100vh;
        margin: 0;
        padding: 0;
        }

        .nav-active {
        background: linear-gradient(90deg, #B300FF 0%, #FF00A0 100%);
        color: white !important;
        box-shadow: 0 0 20px rgba(255, 0, 160, 0.4);
        }

        /* Efekt gradientu tła */
        .bg-gradient-overlay {
        background: radial-gradient(ellipse at top, rgba(179, 0, 255, 0.15) 0%, transparent 50%);
        }

        /* Dodatkowe zabezpieczenie przed białym tłem */
        * {
        box-sizing: border-box;
        }
    </style>
</head>
<body class="antialiased font-sans flex flex-col min-h-screen bg-gradient-overlay">

    <header class="flex justify-between items-center p-6 max-w-7xl mx-auto w-full sticky top-0 z-50 backdrop-blur-md bg-black/30 border-b border-white/5">
        <div class="flex items-center space-x-2">
            <div class="w-8 h-8 bg-gradient-to-br from-[#B300FF] to-[#FF00A0] rounded-lg flex items-center justify-center text-white shadow-[0_0_15px_rgba(255,0,160,0.5)] rotate-45">
                <svg class="w-5 h-5 -rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
            </div>
            <div>
                <span class="text-white font-bold text-xl tracking-tighter uppercase block">Promilex<span class="text-[#FF00A0]">.</span></span>
                <span class="text-gray-500 text-[10px] tracking-[0.3em] uppercase block -mt-1">Premium Spirits</span>
            </div>
        </div>

        <nav class="hidden md:flex space-x-2 bg-[#130B24]/60 rounded-full px-2 py-2 border border-white/5 shadow-2xl">
            <a href="@Url.Action("Index", "Home")" class="px-5 py-2 rounded-full text-sm font-medium transition-all @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "nav-active" : "text-gray-400 hover:text-white")">
                ✨ Strona główna
            </a>
            <a href="@Url.Action("Shop", "Home")" class="px-5 py-2 rounded-full text-sm font-medium transition-all @(ViewContext.RouteData.Values["Action"]?.ToString() == "Shop" ? "nav-active" : "text-gray-400 hover:text-white")">
                📦 Produkty
            </a>
            <a href="@Url.Action("Contact", "Home")" class="px-5 py-2 rounded-full text-sm font-medium transition-all @(ViewContext.RouteData.Values["Action"]?.ToString() == "Contact" ? "nav-active" : "text-gray-400 hover:text-white")">
                📞 Kontakt
            </a>
        </nav>

        <!-- USUNIĘTO PRZYCISK "PANEL PRACOWNIKA" STĄD - JEST TYLKO W STOPCE -->
        <div class="w-[140px] hidden md:block"></div>
    </header>

    <main class="flex-grow flex flex-col items-center p-8 max-w-7xl mx-auto w-full">
        @RenderBody()
    </main>

    <footer class="py-10 text-center border-t border-white/5 mt-auto">
        <div class="max-w-7xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center">
            <p class="text-gray-600 text-[10px] tracking-[0.2em] uppercase mb-4 md:mb-0">
                &copy; 2026 PROMILEX. Wszelkie prawa zastrzeżone.
            </p>

            <!-- TUTAJ JEST DYSKRETNY LINK DO PANELU ADMINA (TYLKO W STOPCE) -->
            <div class="space-x-4">
                <a href="#" class="text-gray-600 hover:text-gray-400 text-[10px] tracking-[0.2em] uppercase transition-colors">Regulamin</a>
                <span class="text-gray-800">|</span>
                <a href="@Url.Action("Login", "Admin")" class="text-gray-700 hover:text-gray-500 text-[10px] tracking-[0.2em] uppercase transition-colors">Panel Pracownika</a>
            </div>
        </div>
    </footer>

</body>
</html>