@model WebBusinessPromilexApp.Models.Product

@{
    ViewData["Title"] = "Szczegóły Produktu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 flex justify-between items-center">
    <div>
        <h2 class="text-4xl font-bold text-white tracking-tight">Karta produktu</h2>
        <p class="text-gray-500 mt-1">Szczegółowe informacje o asortymencie</p>
    </div>
    <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors flex items-center">
        Wróć do listy
    </a>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-2xl p-8 shadow-2xl backdrop-blur-sm">
    <div class="flex items-center justify-between mb-8 border-b border-white/5 pb-6">
        <div>
            <h3 class="text-3xl font-bold text-white">@Model.Name</h3>
        </div>
        <div class="text-right">
            <p class="text-3xl font-bold text-[#FF00A0]">@Model.Price.ToString("0.00") PLN</p>
            <p class="text-sm text-gray-400 mt-1">Stan: @Model.Stock szt.</p>
        </div>
    </div>

    <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-6">
        <div>
            <dt class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-1">Status dostępności</dt>
            <dd>
                @if (Model.IsAvailable)
                {
                    <span class="px-3 py-1 bg-green-500/10 text-green-400 border border-green-500/20 rounded-full text-xs font-bold shadow-[0_0_15px_rgba(34,197,94,0.1)]">Dostępny w sklepie</span>
                }
                else
                {
                    <span class="px-3 py-1 bg-red-500/10 text-red-400 border border-red-500/20 rounded-full text-xs font-bold">Niedostępny</span>
                }
            </dd>
        </div>
        <div>
            <dt class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-1">Zdjęcie</dt>
            <dd class="text-white bg-[#0D051A] px-4 py-3 rounded-xl border border-white/5">@(string.IsNullOrEmpty(Model.ImageUrl) ? "Brak" : Model.ImageUrl)</dd>
        </div>
    </dl>

    <div class="flex justify-end pt-8 mt-8 border-t border-white/5">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="px-8 py-3 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl border border-white/10 transition-all">Edytuj produkt</a>
    </div>
</div>
