@model WebBusinessPromilexApp.Models.Message

@{
    ViewData["Title"] = "Kontakt";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="max-w-6xl w-full py-12 px-4 mx-auto">
    <h2 class="text-4xl font-bold text-[#FF00A0] mb-4 text-center">Skontaktuj się z nami</h2>
    <p class="text-gray-400 mb-12 text-center">Masz pytania? Jesteśmy do Twojej dyspozycji.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="max-w-3xl mx-auto mb-8 p-4 bg-green-500/10 border border-green-500/50 rounded-xl text-green-400 text-center animate-pulse">
            <i class="ri-checkbox-circle-fill mr-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-1">
            <div class="bg-gradient-to-br from-[#1E1332] to-[#0D051A] p-8 rounded-2xl border border-white/10 shadow-2xl">
                <h3 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
                    <svg class="w-6 h-6 text-[#FF00A0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    Napisz do nas
                </h3>

                <form asp-controller="Home" asp-action="Contact" method="post" class="space-y-5">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs"></div>
                    
                    <div>
                        <label asp-for="SenderName" class="block text-sm text-gray-400 mb-2">Imię i nazwisko</label>
                        <input asp-for="SenderName" type="text" class="w-full bg-[#0D051A] border border-white/10 rounded-lg px-4 py-3 text-white focus:border-[#FF00A0] focus:ring-1 focus:ring-[#FF00A0]/30 outline-none transition-all" placeholder="Jan Kowalski" required>
                            <span asp-validation-for="SenderName" class="text-red-500 text-xs mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Email" class="block text-sm text-gray-400 mb-2">Email</label>
                            <input asp-for="Email" type="email" class="w-full bg-[#0D051A] border border-white/10 rounded-lg px-4 py-3 text-white focus:border-[#FF00A0] focus:ring-1 focus:ring-[#FF00A0]/30 outline-none transition-all" placeholder="jan@example.com" required>
                                <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                            </div>
                            <div>
                                <label asp-for="Phone" class="block text-sm text-gray-400 mb-2">Telefon</label>
                                <input asp-for="Phone" type="tel" class="w-full bg-[#0D051A] border border-white/10 rounded-lg px-4 py-3 text-white focus:border-[#FF00A0] focus:ring-1 focus:ring-[#FF00A0]/30 outline-none transition-all" placeholder="+48 123 456 789">
                                </div>
                                <div>
                                    <label asp-for="Content" class="block text-sm text-gray-400 mb-2">Wiadomość</label>
                                    <textarea asp-for="Content" rows="4" class="w-full bg-[#0D051A] border border-white/10 rounded-lg px-4 py-3 text-white focus:border-[#FF00A0] focus:ring-1 focus:ring-[#FF00A0]/30 outline-none transition-all" placeholder="Twoja wiadomość..." required></textarea>
                                    <span asp-validation-for="Content" class="text-red-500 text-xs mt-1"></span>
                                </div>
                                <button type="submit" class="w-full py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-lg shadow-[0_0_20px_rgba(179,0,255,0.4)] hover:shadow-[0_0_30px_rgba(179,0,255,0.6)] transition-all flex items-center justify-center gap-2 group">
                                    <svg class="w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                                    </svg>
                                    Wyślij wiadomość
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="lg:col-span-2 space-y-6">
                        <div class="bg-gradient-to-br from-[#1E1332] to-[#0D051A] p-8 rounded-2xl border border-white/10">
                            <div class="flex items-center gap-4 mb-4">
                                <div class="p-4 bg-[#FF00A0]/10 rounded-full text-[#FF00A0]">
                                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4 class="font-bold text-white text-lg">Mapa lokalizacji</h4>
                                    <p class="text-sm text-gray-400">ul. Przykładowa 123, Warszawa</p>
                                </div>
                            </div>
                            <div class="bg-[#0D051A] rounded-xl h-48 flex items-center justify-center border border-white/5 relative overflow-hidden">
                                <div class="absolute inset-0 opacity-30 bg-[url('https://www.google.com/maps/d/u/0/thumbnail?mid=1_vK0O_7T8xN6M_UvC9H_m3_8_0o')] bg-cover bg-center"></div>
                                <p class="text-gray-300 relative z-10 font-bold bg-[#0D051A]/80 px-4 py-2 rounded-lg border border-white/10">Mapa Google</p>
                            </div>
                        </div>

                        <div class="bg-gradient-to-br from-[#1E1332] to-[#0D051A] p-8 rounded-2xl border border-white/10">
                            <h4 class="font-bold text-white text-lg mb-4">Znajdź nas w social media</h4>
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                                <a href="#" class="flex items-center gap-4 p-4 bg-[#0D051A] rounded-lg border border-white/5 hover:border-[#FF00A0]/40 transition-all group">
                                    <div class="p-2 bg-[#1877F2]/20 rounded-lg text-[#1877F2]">
                                        <i class="ri-facebook-box-fill text-2xl"></i>
                                    </div>
                                    <span class="text-white font-medium group-hover:text-[#FF00A0] transition-colors">Facebook</span>
                                </a>
                                <a href="#" class="flex items-center gap-4 p-4 bg-[#0D051A] rounded-lg border border-white/5 hover:border-[#FF00A0]/40 transition-all group">
                                    <div class="p-2 bg-[#E4405F]/20 rounded-lg text-[#E4405F]">
                                        <i class="ri-instagram-line text-2xl"></i>
                                    </div>
                                    <span class="text-white font-medium group-hover:text-[#FF00A0] transition-colors">Instagram</span>
                                </a>
                                <a href="#" class="flex items-center gap-4 p-4 bg-[#0D051A] rounded-lg border border-white/5 hover:border-[#FF00A0]/40 transition-all group">
                                    <div class="p-2 bg-[#1DA1F2]/20 rounded-lg text-[#1DA1F2]">
                                        <i class="ri-twitter-x-fill text-2xl"></i>
                                    </div>
                                    <span class="text-white font-medium group-hover:text-[#FF00A0] transition-colors">Twitter</span>
                                </a>
                            </div>
                        </div>

                        <div class="bg-gradient-to-br from-[#1E1332] to-[#0D051A] p-8 rounded-2xl border border-white/10">
                            <h4 class="font-bold text-white text-lg mb-2">Szybki kontakt</h4>
                            <p class="text-gray-400 text-sm mb-6">Odpowiadamy w godzinach pracy sklepu.</p>
                            <div class="flex flex-wrap gap-4">
                                <a href="tel:+48123456789" class="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-lg shadow-[0_0_20px_rgba(179,0,255,0.4)] transition-all">
                                    <i class="ri-phone-fill"></i> Zadzwoń
                                </a>
                                <a href="mailto:kontakt@promilex.pl" class="flex items-center gap-2 px-6 py-3 bg-[#0D051A] border border-white/10 text-white font-bold rounded-lg hover:border-[#FF00A0]/40 transition-all">
                                    <i class="ri-mail-send-line"></i> Email
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>