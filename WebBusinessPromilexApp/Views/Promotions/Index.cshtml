@model IEnumerable<WebBusinessPromilexApp.Models.Promotion>

@{
    ViewData["Title"] = "Promocje";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 flex justify-between items-center px-4">
    <div>
        <h2 class="text-4xl font-black text-white tracking-tighter uppercase italic">
            AKCJE <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#B300FF] to-[#FF00A0] drop-shadow-[0_0_10px_rgba(255,0,160,0.5)]">PROMO</span>
        </h2>
        <p class="text-gray-500 mt-1 uppercase text-[10px] tracking-widest font-bold">Zarządzaj kampaniami rabatowymi sklepu</p>
    </div>
    <a asp-action="Create" class="px-8 py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-2xl shadow-[0_0_25px_rgba(179,0,255,0.4)] hover:shadow-[0_0_40px_rgba(179,0,255,0.6)] transition-all hover:scale-105 transform">
        + NOWA KAMPANIA
    </a>
</div>

<div class="bg-[#1E1332]/40 border border-white/5 rounded-3xl shadow-2xl backdrop-blur-xl overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-[#0D051A]/80 border-b border-white/10 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                <th class="p-6">Nazwa Kampanii</th>
                <th class="p-6">Zniżka</th>
                <th class="p-6">Czas trwania</th>
                <th class="p-6">Status</th>
                <th class="p-6 text-right">Zarządzaj</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
            @foreach (var item in Model)
            {
                bool isActive = item.StartDate <= DateTime.Now && item.EndDate >= DateTime.Now;
                <tr class="hover:bg-white/[0.03] transition-all group">
                    <td class="p-6 text-white font-bold tracking-wide">@item.Name</td>
                    <td class="p-6">
                        <span class="text-2xl font-black text-[#FF00A0] drop-shadow-[0_0_5px_rgba(255,0,160,0.3)]">-@item.DiscountPercentage%</span>
                    </td>
                    <td class="p-6 text-gray-400 text-xs font-mono">
                        @item.StartDate.ToString("dd.MM.yyyy") <i class="ri-arrow-right-line mx-1"></i> @item.EndDate.ToString("dd.MM.yyyy")
                    </td>
                    <td class="p-6">
                        @if (isActive)
                        {
                            <span class="px-3 py-1 bg-green-500/10 text-green-400 border border-green-500/20 rounded-full text-[10px] font-bold uppercase tracking-tighter">Aktywna</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 bg-gray-500/10 text-gray-500 border border-white/5 rounded-full text-[10px] font-bold uppercase tracking-tighter">Nieaktywna</span>
                        }
                    </td>
                    <td class="p-6 text-right space-x-3">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="text-xs font-bold text-[#B300FF] hover:text-[#FF00A0] transition-colors uppercase">Edytuj</a>
                        <span class="text-white/10">|</span>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="text-xs font-bold text-red-500 hover:text-red-400 transition-colors uppercase">Usuń</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>