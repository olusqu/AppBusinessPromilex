@model WebBusinessPromilexApp.Models.Category

@{
    ViewData["Title"] = "Dodaj Kategorię";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="mb-8">
    <h2 class="text-4xl font-bold text-white tracking-tight">Nowa kategoria</h2>
    <p class="text-gray-500 mt-1">Zdefiniuj nową grupę asortymentu</p>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-2xl p-8 shadow-2xl backdrop-blur-sm">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs font-semibold bg-red-500/10 p-3 rounded-lg border border-red-500/20 mb-6"></div>

        <div class="space-y-6">
            <div>
                <label asp-for="Name" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Nazwa Kategorii</label>
                <input asp-for="Name" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" placeholder="np. Whisky Single Malt" />
                <span asp-validation-for="Name" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
            </div>
            
            <div>
                <label asp-for="ImageUrl" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Link do zdjęcia (URL)</label>
                <input asp-for="ImageUrl" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#B300FF] transition-all" placeholder="https://..." />
                <span asp-validation-for="ImageUrl" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
            </div>

            <div>
                <label asp-for="Description" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Opis</label>
                <textarea asp-for="Description" rows="4" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" placeholder="Krótki opis tej grupy produktów..."></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
            </div>

            <div class="flex justify-end items-center space-x-6 pt-8 border-t border-white/5">
                <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">Anuluj</a>
                <button type="submit" class="px-10 py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-xl shadow-[0_0_20px_rgba(179,0,255,0.4)] hover:shadow-[0_0_30px_rgba(179,0,255,0.6)] transition-all">
                    Zapisz Kategorię
                </button>
            </div>
        </div>
    </form>
</div>