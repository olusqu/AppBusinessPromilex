@model WebBusinessPromilexApp.Models.Promotion

@{
    ViewData["Title"] = "Szczegóły Kampanii";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="mb-10 flex justify-between items-end">
    <div>
        <h2 class="text-4xl font-black text-white tracking-tighter uppercase italic">KARTA <span class="text-[#B300FF]">KAMPANII</span></h2>
        <p class="text-gray-500 mt-2 text-[10px] uppercase tracking-widest font-bold">Szczegółowe dane</p>
    </div>
    <a asp-action="Index" class="text-xs font-bold text-gray-500 hover:text-white uppercase transition-colors">Powrót do listy</a>
</div>

<div class="max-w-4xl bg-[#1E1332]/50 border border-white/5 rounded-3xl p-10 shadow-2xl backdrop-blur-md">
    <div class="flex items-center justify-between mb-12 border-b border-white/5 pb-8">
        <div>
            <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Nazwa systemowa</h3>
            <p class="text-3xl font-bold text-white">@Model.Name</p>
        </div>
        <div class="text-right">
            <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Moc rabatu</h3>
            <div class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#B300FF] to-[#FF00A0]">
                -@Model.DiscountPercentage%
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
        <div class="bg-[#0D051A]/80 p-6 rounded-2xl border border-white/5">
            <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Czas aktywacji</h3>
            <p class="text-white font-mono text-lg">@Model.StartDate.ToString("f")</p>
        </div>
        <div class="bg-[#0D051A]/80 p-6 rounded-2xl border border-white/5">
            <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Czas wygaśnięcia</h3>
            <p class="text-white font-mono text-lg">@Model.EndDate.ToString("f")</p>
        </div>
    </div>

    <div class="bg-[#0D051A]/50 p-8 rounded-2xl border border-white/5">
        <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-4">
            Produkty objęte promocją (@(Model.Products?.Count ?? 0))
        </h3>
        
        @if (Model.Products != null && Model.Products.Any())
        {
            <div class="flex flex-wrap gap-3">
                @foreach (var product in Model.Products)
                {
                    <div class="bg-gradient-to-r from-[#1E1332] to-[#0D051A] border border-white/10 px-4 py-2 rounded-lg flex items-center space-x-3 group">
                        <span class="w-2 h-2 rounded-full bg-[#FF00A0] group-hover:animate-pulse"></span>
                        <span class="text-sm text-gray-300 font-medium">@product.Name</span>
                        <span class="text-xs text-[#FF00A0] font-bold">@product.Price zł</span>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-6 border border-dashed border-white/10 rounded-xl">
                <p class="text-gray-500 text-sm">Brak przypisanych produktów do tej kampanii.</p>
            </div>
        }
    </div>

    <div class="flex justify-end pt-12 mt-12 border-t border-white/5">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="px-10 py-4 bg-white/5 text-white font-bold rounded-xl border border-white/10 hover:bg-white/10 transition-all uppercase text-xs tracking-widest">
            Edytuj parametry
        </a>
    </div>
</div>