@model WebBusinessPromilexApp.Models.Order

@{
    ViewData["Title"] = "Edytuj Zamówienie";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h2 class="text-4xl font-bold text-white tracking-tight">Edytuj zamówienie</h2>
    <p class="text-gray-500 mt-1">Aktualizuj status i dane transakcji</p>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-2xl p-8 shadow-2xl backdrop-blur-sm">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="CustomerId" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Klient</label>
                    <select asp-for="CustomerId" asp-items="ViewBag.CustomerId" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all"></select>
                </div>
                <div>
                    <label asp-for="Status" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Status</label>
                    <input asp-for="Status" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0]" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="TotalAmount" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Kwota (PLN)</label>
                    <input asp-for="TotalAmount" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white" />
                </div>
                <div>
                    <label asp-for="OrderDate" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Data</label>
                    <input asp-for="OrderDate" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white" />
                </div>
            </div>

            <div class="flex justify-end items-center space-x-6 pt-8 border-t border-white/5">
                <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">Anuluj</a>
                <button type="submit" class="px-10 py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-xl shadow-[0_0_20px_rgba(179,0,255,0.4)]">
                    Zapisz Zmiany
                </button>
            </div>
        </div>
    </form>
</div>