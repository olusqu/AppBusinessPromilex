@model WebBusinessPromilexApp.Models.Supplier

@{
    ViewData["Title"] = "Szczegóły Dostawcy";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 flex justify-between items-center">
    <div>
        <h2 class="text-4xl font-bold text-white tracking-tight">Karta dostawcy</h2>
        <p class="text-gray-500 mt-1">Podgląd danych kontaktowych</p>
    </div>
    <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors flex items-center">
        Wróć do listy
    </a>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-2xl p-8 shadow-2xl backdrop-blur-sm">
    <div class="mb-8 border-b border-white/5 pb-6">
        <h3 class="text-2xl font-bold text-[#B300FF]">@Model.CompanyName</h3>
    </div>

    <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-6">
        <div class="bg-[#0D051A] p-4 rounded-xl border border-white/5">
            <dt class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-1">Osoba Kontaktowa</dt>
            <dd class="text-white text-lg">@Model.ContactPerson</dd>
        </div>
        <div class="bg-[#0D051A] p-4 rounded-xl border border-white/5">
            <dt class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-1">Telefon</dt>
            <dd class="text-white font-mono text-lg">@Model.Phone</dd>
        </div>
    </dl>

    <div class="flex justify-end pt-8 mt-8 border-t border-white/5">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="px-8 py-3 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl border border-white/10 transition-all">
            Edytuj dane
        </a>
    </div>
</div>