@{
    ViewData["Title"] = "Strona Główna";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="text-center space-y-8 py-20 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#B300FF]/10 via-transparent to-transparent pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4">
        <div class="text-[#FF00A0] text-5xl mb-6 animate-pulse">
            <svg class="w-16 h-16 mx-auto drop-shadow-[0_0_15px_rgba(255,0,160,0.5)]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
        </div>

        <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-white leading-tight">
            Witaj w przyszłości<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#B300FF] to-[#FF00A0]">
                zakupów alkoholi premium
            </span>
        </h1>

        <p class="text-gray-400 text-lg max-w-2xl mx-auto mt-6">
            Odkryj naszą ekskluzywną kolekcję najlepszych alkoholi z całego świata.<br />
            Doświadczenie, jakość i prestiż w jednym miejscu.
        </p>

        <div class="pt-10">
            <a href="@Url.Action("Shop", "Home")" class="inline-flex items-center px-10 py-5 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-full shadow-[0_0_30px_rgba(179,0,255,0.4)] hover:shadow-[0_0_50px_rgba(179,0,255,0.6)] hover:scale-105 transition-all duration-300">
                Przeglądaj kolekcję
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </div>
</div>

<div class="w-full py-16 border-t border-white/5 bg-[#0D051A]/50">
    <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-white mb-12 uppercase tracking-wider">Kategorie produktów</h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @if (ViewBag.Categories != null)
            {
                foreach (var cat in ViewBag.Categories as IEnumerable<WebBusinessPromilexApp.Models.Category>)
                {
                    <a href="@Url.Action("Shop", "Home", new { categoryId = cat.Id })" class="block group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#FF00A0]/40 transition-all duration-300 hover:shadow-[0_0_30px_rgba(255,0,160,0.2)] text-center">
                        <div class="bg-[#0D051A] rounded-full w-24 h-24 mx-auto mb-4 border border-white/10 group-hover:border-[#B300FF]/50 transition-all overflow-hidden relative shadow-lg flex items-center justify-center">
                            @if (!string.IsNullOrEmpty(cat.ImageUrl))
                            {
                                <img src="@cat.ImageUrl" alt="@cat.Name" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500" />
                            }
                            else
                            {
                                string initials = string.IsNullOrEmpty(cat.Name) ? "X" : cat.Name.Substring(0, Math.Min(2, cat.Name.Length)).ToUpper();
                                <div class="text-2xl font-bold text-[#FF00A0]">@initials</div>
                            }
                        </div>
                        <h3 class="text-white font-bold text-xl mb-1">@cat.Name</h3>
                        <p class="text-gray-500 text-sm truncate px-2">@(string.IsNullOrEmpty(cat.Description) ? "Zobacz ofertę" : cat.Description)</p>
                    </a>
                }
            }
        </div>
    </div>
</div>

<div class="w-full py-16">
    <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-white mb-12 uppercase tracking-wider">Produkty premium</h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @if (ViewBag.PremiumProducts != null)
            {
                foreach (var prod in ViewBag.PremiumProducts as IEnumerable<WebBusinessPromilexApp.Models.Product>)
                {
                    var activePromo = prod.Promotions?.FirstOrDefault(p => p.StartDate <= DateTime.Now && p.EndDate >= DateTime.Now);

                    <div class="bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-5 border border-white/5 hover:border-[#FF00A0]/40 transition-all flex flex-col group shadow-xl relative">
                        
                        @if (activePromo != null)
                        {
                            <span class="absolute top-4 right-4 bg-gradient-to-r from-[#FF00A0] to-[#B300FF] text-white text-[10px] font-black px-3 py-1 rounded-full z-10 shadow-[0_0_15px_rgba(255,0,160,0.6)] uppercase tracking-wider animate-pulse">
                                -@activePromo.DiscountPercentage%
                            </span>
                        }

                        <div class="bg-[#0D051A] rounded-xl h-48 mb-5 overflow-hidden relative border border-white/5 flex items-center justify-center">
                            @if (!string.IsNullOrEmpty(prod.ImageUrl))
                            {
                                <img src="@prod.ImageUrl" alt="@prod.Name" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500" />
                            }
                            else
                            {
                                string prodInitials = string.IsNullOrEmpty(prod.Name) ? "P" : prod.Name.Substring(0, Math.Min(2, prod.Name.Length)).ToUpper();
                                <div class="text-4xl font-bold text-[#B300FF]/20">@prodInitials</div>
                            }
                        </div>
                        <div class="flex items-center text-yellow-400 text-xs mb-3">
                            <i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i>
                        </div>
                        <h3 class="text-white font-bold text-lg mb-1 leading-tight">@prod.Name</h3>
                        <p class="text-gray-500 text-xs mb-3 uppercase tracking-wider">Premium</p>
                        
                        <div class="mt-auto pt-4 border-t border-white/5 flex flex-col gap-3">
                            <div class="text-2xl font-bold text-white">
                                @if (activePromo != null)
                                {
                                    var discountedPrice = prod.Price * (1 - (activePromo.DiscountPercentage / 100m));
                                    <div class="flex flex-col">
                                        <span class="text-sm text-gray-500 line-through mb-1">@prod.Price.ToString("0.00") zł</span>
                                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#B300FF] to-[#FF00A0]">@discountedPrice.ToString("0.00") <span class="text-sm font-normal text-gray-400">zł</span></span>
                                    </div>
                                }
                                else
                                {
                                    <span>@prod.Price.ToString("0.00") <span class="text-sm font-normal text-gray-400">zł</span></span>
                                }
                            </div>
                            
                            <form asp-controller="Cart" asp-action="Add" method="post" class="w-full m-0">
                                <input type="hidden" name="productId" value="@prod.Id" />
                                <button type="submit" class="w-full py-2.5 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white rounded-lg hover:shadow-[0_0_15px_rgba(179,0,255,0.6)] transition-all flex items-center justify-center gap-2 font-bold hover:scale-[1.02]">
                                    <i class="ri-shopping-cart-2-line text-lg"></i>
                                    Dodaj do koszyka
                                </button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="w-full py-16 border-t border-white/5 bg-[#0D051A]/30">
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="text-center p-8 bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl border border-white/5">
                <i class="ri-shield-star-line text-5xl text-[#FF00A0] mb-4 inline-block drop-shadow-[0_0_10px_rgba(255,0,160,0.4)]"></i>
                <h3 class="text-xl font-bold text-white mb-2">Najwyższa jakość</h3>
                <p class="text-gray-400">Tylko oryginalne produkty od sprawdzonych producentów.</p>
            </div>
            <div class="text-center p-8 bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl border border-white/5">
                <i class="ri-money-dollar-circle-line text-5xl text-[#B300FF] mb-4 inline-block drop-shadow-[0_0_10px_rgba(179,0,255,0.4)]"></i>
                <h3 class="text-xl font-bold text-white mb-2">Najlepsze ceny</h3>
                <p class="text-gray-400">Konkurencyjne ceny i ekskluzywne, regularne promocje.</p>
            </div>
            <div class="text-center p-8 bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl border border-white/5">
                <i class="ri-secure-payment-line text-5xl text-[#FF00A0] mb-4 inline-block drop-shadow-[0_0_10px_rgba(255,0,160,0.4)]"></i>
                <h3 class="text-xl font-bold text-white mb-2">Pewność zakupów</h3>
                <p class="text-gray-400">Gwarancja autentyczności i bezpiecznej dostawy pod drzwi.</p>
            </div>
        </div>
    </div>
</div>