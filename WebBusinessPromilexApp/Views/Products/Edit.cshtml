@model WebBusinessPromilexApp.Models.Product

@{
    ViewData["Title"] = "Edytuj Produkt";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h2 class="text-4xl font-bold text-white tracking-tight">Edytuj produkt</h2>
    <p class="text-gray-500 mt-1">Zaktualizuj dane asortymentu w systemie PROMILEX</p>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-2xl p-8 shadow-2xl backdrop-blur-sm">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs font-semibold bg-red-500/10 p-3 rounded-lg border border-red-500/20 mb-6"></div>
        <input type="hidden" asp-for="Id" />

        <div class="space-y-6">
            <div>
                <label asp-for="Name" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Nazwa produktu</label>
                <input asp-for="Name" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                <span asp-validation-for="Name" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Price" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Cena (PLN)</label>
                    <input asp-for="Price" type="number" step="0.01" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                    <span asp-validation-for="Price" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
                </div>
                <div>
                    <label asp-for="Stock" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Ilość w magazynie</label>
                    <input asp-for="Stock" type="number" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                    <span asp-validation-for="Stock" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
                </div>
            </div>

            <div>
                <label asp-for="ImageUrl" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Link do zdjęcia</label>
                <input asp-for="ImageUrl" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                <span asp-validation-for="ImageUrl" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
            </div>

            <div class="flex items-center space-x-4 p-4 bg-white/[0.02] rounded-xl border border-white/5">
                <input asp-for="IsAvailable" class="w-6 h-6 bg-[#0D051A] border-white/20 rounded-md accent-[#FF00A0] cursor-pointer" />
                <label asp-for="IsAvailable" class="text-sm font-semibold text-gray-300 cursor-pointer">Produkt jest dostępny do zakupu</label>
            </div>

            <div class="flex justify-end items-center space-x-6 pt-8 border-t border-white/5">
                <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">Anuluj i wróć</a>
                <button type="submit" class="px-10 py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-xl shadow-[0_0_20px_rgba(179,0,255,0.4)] hover:shadow-[0_0_30px_rgba(179,0,255,0.6)] transition-all transform hover:-translate-y-0.5">
                    Zapisz Zmiany
                </button>
            </div>
        </div>
    </form>
</div>
