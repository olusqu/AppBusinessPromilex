@model IEnumerable<WebBusinessPromilexApp.Models.Product>
@{
    ViewData["Title"] = "Pełny Asortyment";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="w-full pt-8">
    <h2 class="text-4xl font-bold text-white mb-2">Pełny Asortyment <span class="text-[#FF00A0]">Premium</span></h2>
    <p class="text-gray-400 mb-12">Odkryj ekskluzywną kolekcję produktów z całego świata.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        @foreach (var item in Model)
        {
            <div class="bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-5 border border-white/5 hover:border-[#FF00A0]/40 transition-all flex flex-col group shadow-xl relative">

                <div class="bg-[#0D051A] rounded-xl h-48 flex items-center justify-center mb-5 relative overflow-hidden">
                    <span class="text-[#B300FF] opacity-40 group-hover:opacity-70 group-hover:scale-110 transition-all duration-300">
                        <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                        </svg>
                    </span>
                </div>

                <div class="flex items-center text-yellow-400 text-xs mb-3">
                    @for (int i = 0; i < 5; i++)
                    {
                        <svg class="w-4 h-4 mr-0.5" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                        </svg>
                    }
                </div>

                <div class="flex-grow">
                    <h3 class="text-white font-bold text-lg mb-1">@item.Name</h3>
                    <p class="text-gray-500 text-xs mb-3 uppercase tracking-wider">Premium</p>

                    @if (item.IsAvailable)
                    {
                        <span class="px-3 py-1 bg-green-500/10 text-green-400 text-[10px] font-bold rounded-full border border-green-500/20">Dostępny</span>
                    }
                    else
                    {
                        <span class="px-3 py-1 bg-red-500/10 text-red-400 text-[10px] font-bold rounded-full border border-red-500/20">Niedostępny</span>
                    }
                </div>

                <div class="mt-6 pt-4 border-t border-white/5">
                    <div class="text-2xl font-bold text-white mb-4">@item.Price.ToString("0.00") zł</div>
                    <button class="w-full py-3 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-semibold rounded-lg shadow-[0_0_15px_rgba(179,0,255,0.3)] hover:shadow-[0_0_25px_rgba(179,0,255,0.6)] transition-all flex items-center justify-center gap-2 hover:scale-[1.02]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                        </svg>
                        Dodaj do koszyka
                    </button>
                </div>
            </div>
        }
    </div>
</div>
