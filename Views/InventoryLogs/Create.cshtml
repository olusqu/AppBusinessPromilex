@model WebBusinessPromilexApp.Models.InventoryLog

@{
    ViewData["Title"] = "Rejestracja Ruchu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-10">
    <h2 class="text-4xl font-black text-white tracking-tighter uppercase italic">NOWY <span class="text-[#00F0FF]">LOG</span></h2>
    <p class="text-gray-500 mt-1 uppercase text-xs tracking-widest">Wprowadź zmianę stanu magazynowego</p>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-3xl p-10 shadow-2xl backdrop-blur-md">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs font-bold mb-6"></div>

        <div class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="ProductId" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-3">Produkt</label>
                    <select asp-for="ProductId" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:border-[#00F0FF] outline-none transition-all" asp-items="ViewBag.ProductId"></select>
                </div>
                <div>
                    <label asp-for="EmployeeId" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-3">Pracownik odpowiedzialny</label>
                    <select asp-for="EmployeeId" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:border-[#00F0FF] outline-none transition-all" asp-items="ViewBag.EmployeeId"></select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-white/5">
                <div>
                    <label asp-for="QuantityChange" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Zmiana ilości (np. -5, 20)</label>
                    <input asp-for="QuantityChange" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white font-bold text-xl focus:border-[#00F0FF] outline-none" placeholder="0" />
                </div>
                <div>
                    <label asp-for="TransactionType" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Typ transakcji</label>
                    <input asp-for="TransactionType" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:border-[#00F0FF] outline-none" placeholder="Dostawa, Sprzedaż..." />
                </div>
            </div>

            <div>
                <label asp-for="Note" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-3">Notatka / Powód zmiany</label>
                <textarea asp-for="Note" rows="3" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:border-[#00F0FF] outline-none" placeholder="Dodatkowy komentarz..."></textarea>
            </div>

            <div class="flex justify-end items-center space-x-6 pt-8 border-t border-white/5">
                <a asp-action="Index" class="text-xs font-bold text-gray-500 hover:text-white uppercase tracking-widest transition-colors">Anuluj</a>
                <button type="submit" class="px-12 py-4 bg-gradient-to-r from-[#00F0FF] to-[#B300FF] text-black font-black rounded-xl shadow-[0_0_20px_rgba(0,240,255,0.3)] hover:shadow-[0_0_40px_rgba(0,240,255,0.5)] transition-all">
                    REJESTRUJ
                </button>
            </div>
        </div>
    </form>
</div>