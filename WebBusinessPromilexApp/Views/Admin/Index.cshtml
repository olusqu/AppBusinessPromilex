@model dynamic
@{
    ViewData["Title"] = "PROMILEX | Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="text-center space-y-8 py-12 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#B300FF]/10 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative z-10">
        <div class="text-[#FF00A0] text-5xl mb-6 animate-pulse">
            <i class="ri-shield-flash-line drop-shadow-[0_0_15px_rgba(255,0,160,0.5)]"></i>
        </div>
        <h1 class="text-4xl md:text-6xl font-black tracking-tighter text-white leading-tight">
            SYSTEM <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#B300FF] to-[#FF00A0]">PROMILEX</span>
        </h1>
        <p class="text-gray-500 uppercase tracking-[0.4em] text-[10px] mt-4 font-bold">Panel Zarządzania</p>
    </div>
</div>

<div class="w-full py-8">
    <h2 class="text-xs font-bold text-gray-500 uppercase tracking-[0.3em] mb-8 border-b border-white/5 pb-4">Moduły Operacyjne</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <a asp-controller="Products" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#FF00A0]/40 transition-all duration-300 relative">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#FF00A0] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-beer-line"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Produkty</h3>
                    <p class="text-gray-400 text-xs">Suma: <span class="text-white">@(ViewBag.TotalProducts ?? 0)</span></p>
                </div>
            </div>
        </a>

        <a asp-controller="Categories" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#B300FF]/40 transition-all duration-300">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#B300FF] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-price-tag-3-line"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Kategorie</h3>
                    <p class="text-gray-400 text-xs">Liczba: <span class="text-white">@(ViewBag.TotalCategories ?? 0)</span></p>
                </div>
            </div>
        </a>

        <a asp-controller="Orders" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#FF00A0]/40 transition-all duration-300">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#FF00A0] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-shopping-cart-2-line"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Zamówienia</h3>
                    <p class="text-gray-400 text-xs">Zarządzaj sprzedażą</p>
                </div>
            </div>
        </a>

        <a asp-controller="Customers" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#B300FF]/40 transition-all duration-300">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#B300FF] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-team-line"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Klienci</h3>
                    <p class="text-gray-400 text-xs">Baza: <span class="text-white">@(ViewBag.TotalCustomers ?? 0)</span></p>
                </div>
            </div>
        </a>

        <a asp-controller="Messages" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#FF00A0]/40 transition-all duration-300">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#FF00A0] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-mail-send-line"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Wiadomości</h3>
                    <p class="text-gray-400 text-xs">Skrzynka odbiorcza</p>
                </div>
            </div>
        </a>

        <a asp-controller="InventoryLogs" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-[#00F0FF]/20 transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,240,255,0.2)]">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#00F0FF] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-history-line text-[#00F0FF] drop-shadow-[0_0_8px_#00F0FF]"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Logi Magazynowe</h3>
                    <p class="text-gray-400 text-xs">Wpisów: <span class="text-[#00F0FF]">@(ViewBag.TotalLogs ?? 0)</span></p>
                </div>
            </div>
        </a>

        <a asp-controller="Suppliers" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#B300FF]/40 transition-all duration-300">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#B300FF] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-truck-line"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Dostawcy</h3>
                    <p class="text-gray-400 text-xs">Kontakty: <span class="text-white">@(ViewBag.TotalSuppliers ?? 0)</span></p>
                </div>
            </div>
        </a>

        <a asp-controller="Employees" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#FF00A0]/40 transition-all duration-300">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#FF00A0] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-shield-user-line"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Pracownicy</h3>
                    <p class="text-gray-400 text-xs">Zespół: <span class="text-white">@(ViewBag.TotalEmployees ?? 0)</span></p>
                </div>
            </div>
        </a>

        <a asp-controller="Promotions" asp-action="Index" class="group bg-gradient-to-br from-[#1E1332] to-[#0D051A] rounded-2xl p-6 border border-white/5 hover:border-[#B300FF]/40 transition-all duration-300">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-[#0D051A] rounded-xl flex items-center justify-center text-[#B300FF] text-2xl border border-white/5 group-hover:scale-110 transition-transform">
                    <i class="ri-percent-line"></i>
                </div>
                <div>
                    <h3 class="text-white font-bold text-lg">Promocje</h3>
                    <p class="text-gray-400 text-xs">Kampanie rabatowe</p>
                </div>
            </div>
        </a>
    </div>
</div>
