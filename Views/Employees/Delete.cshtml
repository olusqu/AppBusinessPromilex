@model WebBusinessPromilexApp.Models.Employee

@{
    ViewData["Title"] = "Usuń Pracownika";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h2 class="text-4xl font-bold text-red-500 tracking-tight">Odbierz dostęp</h2>
    <p class="text-gray-500 mt-1">Czy na pewno chcesz usunąć konto tego pracownika?</p>
</div>

<div class="max-w-2xl bg-[#1E1332]/50 border border-red-500/20 rounded-2xl p-8 shadow-[0_0_30px_rgba(239,68,68,0.1)] backdrop-blur-sm">
    
    <div class="flex items-center space-x-4 bg-[#0D051A] rounded-xl p-6 border border-white/5 mb-8">
        <div class="w-12 h-12 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 font-bold border border-red-500/30">
            !
        </div>
        <div>
            <h3 class="text-white font-bold text-lg">@Model.FirstName @Model.LastName</h3>
            <p class="text-gray-400 text-sm">Rola: @Model.Role | Login: <span class="font-mono text-gray-300">@Model.Username</span></p>
        </div>
    </div>

    <form asp-action="Delete" class="flex justify-end items-center space-x-6 pt-4">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">
            Anuluj
        </a>
        <button type="submit" class="px-8 py-4 bg-red-600 text-white font-bold rounded-xl shadow-[0_0_20px_rgba(220,38,38,0.4)] hover:shadow-[0_0_30px_rgba(220,38,38,0.6)] hover:bg-red-500 transition-all">
            Tak, usuń to konto
        </button>
    </form>
</div>