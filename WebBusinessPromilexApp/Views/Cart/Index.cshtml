@model List<WebBusinessPromilexApp.Models.CartItem>
@{
    ViewData["Title"] = "Twój Koszyk";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    decimal cartTotal = Model?.Sum(x => x.Total) ?? 0;
}

<div class="max-w-7xl mx-auto px-4 py-12">
    <h2 class="text-4xl font-bold text-white mb-2">Twój <span class="text-[#FF00A0]">Koszyk</span></h2>
    <p class="text-gray-400 mb-8">Przejrzyj wybrane produkty przed finalizacją zamówienia.</p>

    @if (Model == null || !Model.Any())
    {
        <div class="bg-[#1E1332]/50 border border-white/5 rounded-3xl p-12 text-center shadow-2xl backdrop-blur-md">
            <i class="ri-shopping-cart-2-line text-6xl text-gray-600 mb-4 inline-block"></i>
            <h3 class="text-2xl font-bold text-white mb-2">Twój koszyk jest pusty</h3>
            <p class="text-gray-500 mb-8">Czas dodać do niego trochę produktów premium!</p>
            <a href="@Url.Action("Shop", "Home")" class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-xl shadow-[0_0_20px_rgba(179,0,255,0.4)] hover:shadow-[0_0_30px_rgba(179,0,255,0.6)] transition-all transform hover:-translate-y-0.5">
                Wróć do sklepu
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-4">
                @foreach (var item in Model)
                {
                    <div class="bg-[#1E1332]/50 border border-white/5 rounded-2xl p-4 flex items-center gap-6 relative shadow-lg">
                        <div class="w-24 h-24 bg-[#0D051A] rounded-xl overflow-hidden flex-shrink-0 border border-white/10 flex items-center justify-center">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="w-full h-full object-cover opacity-80" />
                            }
                            else
                            {
                                <span class="text-2xl font-bold text-[#B300FF]/30">P</span>
                            }
                        </div>
                        
                        <div class="flex-grow">
                            <h4 class="text-white font-bold text-lg">@item.ProductName</h4>
                            <p class="text-[#FF00A0] font-bold">@item.Price.ToString("0.00") zł <span class="text-xs text-gray-500 font-normal">/ szt.</span></p>
                        </div>

                        <div class="flex items-center bg-[#0D051A] rounded-lg border border-white/10">
                            <form asp-action="Decrease" method="post" class="m-0">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="px-3 py-2 text-gray-400 hover:text-[#FF00A0] transition-colors"><i class="ri-subtract-line"></i></button>
                            </form>
                            <span class="px-3 text-white font-bold">@item.Quantity</span>
                            <form asp-action="Add" method="post" class="m-0">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="px-3 py-2 text-gray-400 hover:text-green-400 transition-colors"><i class="ri-add-line"></i></button>
                            </form>
                        </div>

                        <div class="text-right min-w-[100px]">
                            <p class="text-white font-bold text-xl">@item.Total.ToString("0.00") zł</p>
                        </div>

                        <form asp-action="Remove" method="post" class="absolute top-4 right-4">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="text-gray-600 hover:text-red-500 transition-colors">
                                <i class="ri-close-circle-fill text-xl"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>

            <div class="bg-gradient-to-br from-[#1E1332] to-[#0D051A] border border-white/5 rounded-3xl p-8 h-fit shadow-2xl">
                <h3 class="text-xl font-bold text-white mb-6 uppercase tracking-widest text-[12px]">Podsumowanie</h3>
                
                <div class="space-y-4 mb-6 border-b border-white/5 pb-6">
                    <div class="flex justify-between text-gray-400">
                        <span>Wartość produktów</span>
                        <span>@cartTotal.ToString("0.00") zł</span>
                    </div>
                    <div class="flex justify-between text-gray-400">
                        <span>Dostawa</span>
                        <span class="text-green-400 font-bold">Darmowa</span>
                    </div>
                </div>

                <div class="flex justify-between items-end mb-8">
                    <span class="text-white font-bold">Do zapłaty</span>
                    <span class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#B300FF] to-[#FF00A0]">
                        @cartTotal.ToString("0.00") zł
                    </span>
                </div>

                <button class="w-full py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-xl shadow-[0_0_20px_rgba(179,0,255,0.4)] hover:shadow-[0_0_30px_rgba(179,0,255,0.6)] transition-all transform hover:-translate-y-0.5 mb-4">
                    Przejdź do kasy
                </button>

                <form asp-action="Clear" method="post">
                    <button type="submit" class="w-full py-3 bg-white/5 text-gray-400 font-bold rounded-xl hover:bg-white/10 hover:text-white transition-colors text-xs uppercase tracking-wider border border-white/5">
                        Wyczyść koszyk
                    </button>
                </form>
            </div>
        </div>
    }
</div>