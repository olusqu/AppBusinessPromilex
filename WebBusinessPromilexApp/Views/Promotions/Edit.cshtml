@model WebBusinessPromilexApp.Models.Promotion

@{
    ViewData["Title"] = "Edytuj Promocję";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="mb-8">
    <h2 class="text-4xl font-bold text-white tracking-tight">Edytuj promocję</h2>
    <p class="text-gray-500 mt-1">Zaktualizuj parametry i przypisane produkty</p>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-2xl p-8 shadow-2xl backdrop-blur-sm">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-xs font-semibold bg-red-500/10 p-3 rounded-lg border border-red-500/20 mb-6"></div>
        <input type="hidden" asp-for="Id" />

        <div class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Name" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Nazwa kampanii</label>
                    <input asp-for="Name" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                    <span asp-validation-for="Name" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
                </div>
                
                <div>
                    <label asp-for="DiscountPercentage" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Zniżka (%)</label>
                    <input asp-for="DiscountPercentage" type="number" step="0.01" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                    <span asp-validation-for="DiscountPercentage" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-white/5">
                <div>
                    <label asp-for="StartDate" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Data rozpoczęcia</label>
                    <input asp-for="StartDate" type="datetime-local" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                    <span asp-validation-for="StartDate" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
                </div>
                
                <div>
                    <label asp-for="EndDate" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Data zakończenia</label>
                    <input asp-for="EndDate" type="datetime-local" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                    <span asp-validation-for="EndDate" class="text-red-500 text-[10px] mt-2 block font-medium"></span>
                </div>
            </div>

            <div class="pt-6 border-t border-white/5">
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-3">Aktualizuj produkty w promocji</label>
                <p class="text-xs text-gray-400 mb-4">Przytrzymaj <kbd class="bg-gray-800 px-1 rounded">CTRL</kbd> lub <kbd class="bg-gray-800 px-1 rounded">CMD</kbd>, aby zaznaczyć/odznaczyć wiele.</p>
                
                <select name="selectedProductIds" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" multiple="multiple" style="height: 250px;">
                    @if (ViewBag.AllProducts != null)
                    {
                        var assignedProductIds = Model.Products?.Select(p => p.Id).ToList() ?? new List<int>();

                        foreach (var product in ViewBag.AllProducts)
                        {
                            bool isSelected = assignedProductIds.Contains(product.Id);
                            if (isSelected)
                            {
                                <option value="@product.Id" selected="selected" class="py-2 px-3 bg-[#FF00A0]/20 text-[#FF00A0] rounded-md font-bold cursor-pointer mb-1">
                                    [AKTYWNE] @product.Name (@product.Price zł)
                                </option>
                            }
                            else
                            {
                                <option value="@product.Id" class="py-2 px-3 hover:bg-white/10 rounded-md cursor-pointer mb-1 transition-colors">
                                    @product.Name (@product.Price zł)
                                </option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="flex justify-end items-center space-x-6 pt-8 border-t border-white/5">
                <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">Anuluj</a>
                <button type="submit" class="px-10 py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-xl shadow-[0_0_20px_rgba(179,0,255,0.4)] hover:shadow-[0_0_30px_rgba(179,0,255,0.6)] transition-all transform hover:-translate-y-0.5">
                    Zapisz Zmiany
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}