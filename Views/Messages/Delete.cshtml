@model WebBusinessPromilexApp.Models.Message

<div class="max-w-2xl mx-auto py-20 text-center">
    <div class="w-20 h-20 bg-red-500/10 border border-red-500/30 rounded-full flex items-center justify-center mx-auto mb-8 shadow-[0_0_30px_rgba(239,68,68,0.2)]">
        <i class="ri-delete-bin-line text-red-500 text-4xl"></i>
    </div>
    <h2 class="text-3xl font-bold text-white mb-4">Usunąć wiadomość?</h2>
    <p class="text-gray-500 mb-10">Wiadomość od <span class="text-white font-bold">@Model.SenderName</span> zostanie trwale skasowana ze skrzynki.</p>

    <form asp-action="Delete" class="flex justify-center items-center gap-6">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">Anuluj</a>
        <button type="submit" class="px-10 py-4 bg-red-600 text-white font-bold rounded-xl shadow-[0_0_20px_rgba(220,38,38,0.4)] hover:bg-red-700 transition-all">
            Potwierdzam usunięcie
        </button>
    </form>
</div>