@model WebBusinessPromilexApp.Models.Order

@{
    ViewData["Title"] = "Szczegóły Zamówienia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 flex justify-between items-center">
    <div>
        <h2 class="text-4xl font-bold text-white tracking-tight">Zamówienie #@Model.Id</h2>
        <p class="text-gray-500 mt-1">Szczegółowe dane transakcji</p>
    </div>
    <a asp-action="Index" class="text-sm font-bold text-gray-500 hover:text-white transition-colors flex items-center">Wróć do listy</a>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-2xl p-8 shadow-2xl backdrop-blur-sm">
    <div class="flex items-center justify-between mb-8 border-b border-white/5 pb-6">
        <div>
            <h3 class="text-2xl font-bold text-white">Wartość: <span class="text-[#FF00A0]">@Model.TotalAmount.ToString("0.00") PLN</span></h3>
            <p class="text-gray-400 mt-1">Data: @Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</p>
        </div>
        <div class="px-4 py-2 bg-[#B300FF]/10 border border-[#B300FF]/30 rounded-xl text-[#B300FF] font-bold">
            Status: @(Model.Status ?? "Nowe")
        </div>
    </div>

    <div class="flex justify-end pt-8 mt-8 border-t border-white/5">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="px-8 py-3 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl border border-white/10 transition-all">Edytuj zamówienie</a>
    </div>
</div>
