@model WebBusinessPromilexApp.Models.Supplier

@{
    ViewData["Title"] = "Edytuj Dostawcę";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h2 class="text-4xl font-bold text-white tracking-tight">Edytuj dane</h2>
    <p class="text-gray-500 mt-1">Zaktualizuj profil dostawcy</p>
</div>

<div class="max-w-3xl bg-[#1E1332]/50 border border-white/5 rounded-2xl p-8 shadow-2xl backdrop-blur-sm">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div class="space-y-6">
            <div>
                <label asp-for="CompanyName" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Nazwa Firmy</label>
                <input asp-for="CompanyName" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-white/5">
                <div>
                    <label asp-for="ContactPerson" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Osoba Kontaktowa</label>
                    <input asp-for="ContactPerson" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                </div>
                <div>
                    <label asp-for="Phone" class="block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Telefon</label>
                    <input asp-for="Phone" class="w-full bg-[#0D051A] border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-[#FF00A0] transition-all" />
                </div>
            </div>

            <div class="flex justify-end pt-8 border-t border-white/5">
                <button type="submit" class="px-10 py-4 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-xl shadow-[0_0_20px_rgba(179,0,255,0.4)]">
                    Zapisz Zmiany
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}