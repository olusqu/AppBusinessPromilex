@model WebBusinessPromilexApp.Models.InventoryLog

@{
    ViewData["Title"] = "Usuwanie Logu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-2xl mx-auto py-20 text-center">
    <div class="w-24 h-24 bg-red-500/10 border border-red-500/30 rounded-full flex items-center justify-center mx-auto mb-8 shadow-[0_0_40px_rgba(239,68,68,0.2)]">
        <i class="ri-alert-line text-red-500 text-5xl animate-pulse"></i>
    </div>
    <h2 class="text-4xl font-black text-white mb-4 uppercase italic">USUNĄĆ WPIS?</h2>
    <p class="text-gray-500 mb-10 max-w-md mx-auto">
        Usunięcie logu nie spowoduje wycofania zmiany ilości w produkcie. Czy na pewno chcesz usunąć ślad o tej operacji?
    </p>

    <div class="bg-[#1E1332]/50 border border-white/5 rounded-2xl p-6 mb-10 text-left">
        <p class="text-[10px] text-gray-600 uppercase font-bold mb-1">Produkt</p>
        <p class="text-white font-bold mb-4">@Model.Product.Name (@(Model.QuantityChange > 0 ? "+" : "")@Model.QuantityChange)</p>
        <p class="text-[10px] text-gray-600 uppercase font-bold mb-1">Data</p>
        <p class="text-gray-400 font-mono text-xs">@Model.LogDate</p>
    </div>

    <form asp-action="Delete" class="flex justify-center items-center gap-6">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="text-xs font-bold text-gray-500 hover:text-white uppercase tracking-widest transition-colors">Anuluj</a>
        <button type="submit" class="px-10 py-4 bg-red-600 text-white font-black rounded-xl shadow-[0_0_20px_rgba(220,38,38,0.4)] hover:bg-red-700 transition-all">
            TRWALE USUŃ
        </button>
    </form>
</div>