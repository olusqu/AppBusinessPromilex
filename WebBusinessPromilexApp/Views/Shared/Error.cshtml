@{
    ViewData["Title"] = "Błąd";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="text-center space-y-8 py-20">
    <div class="text-red-500 text-6xl">⚠️</div>

    <h1 class="text-5xl font-black text-white">Błąd serwera</h1>

    <p class="text-gray-400 text-xl max-w-2xl mx-auto">
        Wystąpił problem podczas przetwarzania Twojego żądania.<br />
        Najprawdopodobniej nie możemy połączyć się z bazą danych. Spróbuj ponownie za chwilę.
    </p>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="mt-8 max-w-xl mx-auto bg-red-500/10 border border-red-500/20 rounded-xl p-6 text-left">
            <h3 class="text-red-400 font-bold mb-2">Szczegóły błędu:</h3>
            <p class="text-gray-400 text-sm font-mono">@ViewBag.ErrorMessage</p>
        </div>
    }

    <div class="pt-10">
        <a href="@Url.Action("Index", "Home")" class="px-10 py-5 bg-gradient-to-r from-[#B300FF] to-[#FF00A0] text-white font-bold rounded-full shadow-[0_0_30px_rgba(179,0,255,0.4)] hover:scale-105 transition-transform inline-block">
            Powrót na Stronę Główną
        </a>
    </div>
</div>