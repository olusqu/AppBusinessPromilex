<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - PROMILEX Admin</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    
    <style>
        body {
            background: linear-gradient(135deg, #1A0B2E 0%, #0D051A 100%);
            color: white;
            min-height: 100vh;
        }
        .sidebar {
            background-color: #130B24;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }
        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
            color: #9CA3AF;
        }
        .nav-link:hover {
            background: linear-gradient(90deg, #B300FF 0%, #FF00A0 100%);
            color: white;
            opacity: 0.9;
        }
        .nav-active {
            background: rgba(255, 255, 255, 0.05);
            border-right: 3px solid #FF00A0;
            color: white;
        }
    </style>
</head>
<body class="antialiased font-sans">
    <div class="flex h-screen overflow-hidden">
        
        <aside class="w-64 sidebar flex flex-col justify-between hidden md:flex">
            <div class="overflow-y-auto">
                <div class="p-6">
                    <h1 class="text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-[#B300FF] to-[#FF00A0] tracking-tighter italic">
                        PROMILEX <span class="text-xs block font-bold tracking-widest text-gray-500 not-italic uppercase">Admin Panel</span>
                    </h1>
                </div>
                
                <nav class="mt-4 px-4 space-y-2">
                    <a asp-controller="Admin" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-dashboard-line"></i> Dashboard
                    </a>
                    
                    <div class="pt-4 pb-2 px-4 text-[10px] font-bold text-gray-600 uppercase tracking-widest">Katalog</div>
                    <a asp-controller="Products" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-beer-line"></i> Produkty
                    </a>
                    <a asp-controller="Categories" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-price-tag-3-line"></i> Kategorie
                    </a>
                    <a asp-controller="InventoryLogs" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-history-line"></i> Logi Magazynowe
                    </a>

                    <div class="pt-4 pb-2 px-4 text-[10px] font-bold text-gray-600 uppercase tracking-widest">Sprzedaż</div>
                    <a asp-controller="Orders" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-shopping-cart-2-line"></i> Zamówienia
                    </a>
                    <a asp-controller="Customers" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-user-heart-line"></i> Klienci
                    </a>

                    <div class="pt-4 pb-2 px-4 text-[10px] font-bold text-gray-600 uppercase tracking-widest">System</div>
                    <a asp-controller="Messages" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-mail-send-line"></i> Wiadomości
                    </a>
                    <a asp-controller="Suppliers" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-truck-line"></i> Dostawcy
                    </a>
                    <a asp-controller="Employees" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-shield-user-line"></i> Pracownicy
                    </a>
                    <a asp-controller="Promotions" asp-action="Index" class="nav-link px-4 py-3 rounded-xl text-sm font-bold">
                        <i class="ri-percent-line"></i> Promocje
                    </a>
                </nav>
            </div>
            
            <div class="p-6 border-t border-white/5 bg-[#0D051A]/50">
                <a asp-controller="Admin" asp-action="Logout" class="block w-full text-center px-4 py-3 border border-red-500/20 text-red-500 rounded-xl hover:bg-red-500/10 transition-all font-bold text-xs uppercase tracking-widest">
                    <i class="ri-logout-box-r-line mr-2"></i> Wyloguj
                </a>
            </div>
        </aside>

        <main class="flex-1 overflow-y-auto">
            <div class="p-8 max-w-7xl mx-auto">
                @RenderBody()
            </div>
        </main>

    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>